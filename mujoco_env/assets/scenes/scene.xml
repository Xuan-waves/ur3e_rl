<mujoco model="scene">

    <include file="../ur3e_robotiq/ur3e_robotiq.xml" />

    <compiler angle="radian" autolimits="true" />
	
    <option timestep="0.002" integrator="implicitfast" solver="PGS" gravity="0 0 -9.82"
            cone="elliptic" impratio="10" noslip_iterations="3">
		<!--		 <flag multiccd="enable"/>-->
    </option>

	<!-- 利用mujoco软件来调整Visualization->Free Camera->点击Align更新查看，需要在env代码里进行设置，不能自动启用 -->
    <statistic center="1.8 1.1 1.7" extent="0.8" meansize="0.08" />

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />

		<!-- 利用mujoco软件来调整Visualization->Free Camera->点击Align更新查看，需要在env代码里进行设置，不能自动启用 -->
		<global azimuth="210" elevation="-35" offheight="1280" offwidth="1280"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512"
                 height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4"
                 rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"
                  reflectance="0.2" />

        <!--meshes-->
        <mesh name ="table" file="../table/sigmund_table.stl" scale= "1 1 1"/>
		<mesh name ="Apple" file="../fruit/Apple.STL" scale= "0.001 0.001 0.001"/>
		<mesh name ="Banana" file="../fruit/Banana.STL" scale= "0.001 0.001 0.001"/>

		<mesh name="hammer_head" file="../hammer/hammer_head.stl"/>
		<mesh name="hammer_neck" file="../hammer/hammer_neck.stl"/>
		<mesh name="hammer_contact0" file="../hammer/contact0.stl"/>
		<mesh name="hammer_contact1" file="../hammer/contact1.stl"/>

		<mesh name="knife_blade" file="../knife/knife_blade.stl"/>
        <mesh name="knife_handle" file="../knife/knife_handle.stl"/>
        <mesh name="knife_contact0" file="../knife/contact0.stl"/>
        <mesh name="knife_contact1" file="../knife/contact1.stl"/>

		<mesh name="duck" file="../duck/duck.stl" scale= "0.8 0.8 0.8"/>
        <mesh name="duck_contact0" file="../duck/contact0.stl" scale= "0.8 0.8 0.8"/>
        <mesh name="duck_contact1" file="../duck/contact1.stl" scale= "0.8 0.8 0.8"/>
        <mesh name="duck_contact2" file="../duck/contact2.stl" scale= "0.8 0.8 0.8"/>


		<texture name="apple_tex" type="2d" file="../fruit/mesh/red-apple.png"/>
		<material name="apple_mat" texture="apple_tex"/>
		<texture name="banana_tex" type="2d" file="../fruit/mesh/yellow-banana.png"/>
		<material name="banana_mat" texture="banana_tex"/>

    	<material name="hammer_head_mat" rgba="0.7 0.7 0.7 1" specular="0.5"/>
		<material name="hammer_neck_mat" rgba="0.73 0.5 0.39 1" specular="0.5"/>

		<material name="knife_blade_mat" rgba="0.75 0.75 0.75 1" specular="0.5"/>
		<material name="knife_handle_mat" rgba="0.1 0.1 0.1 1"/>

		<material name="duck_mat" rgba="1 1 0 1.0"/>

		
    </asset>

    <worldbody>
        <!-- <light pos="0 0 1.5" dir="0 0 -1" directional="true" /> -->
		<light pos="1.3 0.7 2.5" dir="0 0 -1" directional="true" />
		<geom name="floor" size="0 0 0.05" type="plane" material="groundplane" />
		<geom name="x-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 1 0 0" size="0.01" rgba="1 0 0 1" />
		<geom name="y-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 0 1 0" size="0.01" rgba="0 1 0 1" />
		<geom name="z-aixs" group="2" type="cylinder" contype="0" conaffinity="0"
			fromto="0 0 0 0 0 1" size="0.01" rgba="0 0 1 1" />

		<!-- 利用mujoco软件来调整Rendering->Camera -->
		<!-- <camera name="cam" pos="1.2 0.8 1.6" xyaxes="0 -1 0 1 0 0.2" fovy="90" mode="fixed" /> -->
		<!-- <camera name="base_cam" pos="-0.335 0.578 1.894" xyaxes="-0.000 -1.000 0.000 0.76 -0.000 0.76"/> -->
		<!-- <camera name="base_cam" pos="-0.576 0.634 1.734" xyaxes="-0.026 -1.000  0.000 0.519 -0.014 0.855"/> -->
		<!-- <camera name="base_cam" pos="-0.050 0.569 1.499" xyaxes=" 0.009 -1.000 -0.000 0.570  0.005 0.822"/> -->
		<camera name="base_cam" pos="0.007 0.617 1.157" xyaxes="0.013 -1.000 -0.000 0.229 0.003 0.973"/>


<!-- <camera pos="-0.250 0.569 1.699" xyaxes="0.009 -1.000 -0.000 0.570 0.005 0.822"/> -->

		<!-- 桌面俯视相机：桌子中心 (0.8, 0.6)，桌面高 0.74m，相机高 0.74+0.8=1.54m，垂直俯视 -->
		<!-- <camera name="table_cam" pos="0.8 0.6 1.54" xyaxes="1 0 0  0 1 0" fovy="90" mode="fixed" /> -->
		<camera name="table_cam" pos="0.983 1.659 1.320" xyaxes="-1.000 -0.004 0.000 0.002 -0.454 0.891" />

<!-- <camera pos="0.983 1.959 1.620" xyaxes="-1.000 -0.004 0.000 0.002 -0.454 0.891"/> -->

		<!-- scene_cam_marker removed -->

		<body name="right_target" mocap="true" pos="0.8 0.6 0.74" quat="1 0 0 0">
			<!-- X-axis (red) -->
			<geom name="right_target_x_shaft" type="cylinder" fromto="0 0 0  0.05 0 0" size="0.005" rgba="1 0 0 0.8" contype="0" conaffinity="0" group="1"/>
			<!-- Y-axis (green) -->
			<geom name="right_target_y_shaft" type="cylinder" fromto="0 0 0  0 0.05 0" size="0.005" rgba="0 1 0 0.8" contype="0" conaffinity="0" group="1"/>
			<!-- Z-axis (blue) -->
			<geom name="right_target_z_shaft" type="cylinder" fromto="0 0 0  0 0 0.05" size="0.005" rgba="0 0 1 0.8" contype="0" conaffinity="0" group="1"/>
			<site type="sphere" size="0.01" rgba="1 1 0 1" group="1"/>
		</body>


		<!--Zones-->
		<!-- 绿色抓取区：桌子中央，机器人正前方可达范围 -->
		<!-- <body name="zone_pickup" pos="0.78 0.6 0.731" quat="1 0 0 0">
			<geom name="zone_pickup" type="box" size="0.2 0.25 0.008" rgba="0 1 0 0.15" contype="0" conaffinity="0"/>
		</body>
		<body name="zone_drop" pos="0.6 0.2 0.73" quat="1 0 0 0">
			<geom name="zone_drop" type="box" size="0.15 0.15 0.01" rgba="1 0 0 0.1" contype="0" conaffinity="0"/>
		</body> -->

		<!-- <body name="Box" pos="0.8 0.8 0.85" quat="1 0 0 0">
			<joint name="Box" type="free" />
			<geom name="Box" type="box" size="0.025 0.025 0.025" rgba="1 0 1 1" condim="6"/>
		</body> -->

        <!--table -->
		<body name = "table1" euler="0 0 0" pos= "0.8 0 0.74" >
		  <geom name = "table1" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0"/>
		</body>
		<body name = "table2" euler="0 0 0" pos= "1.6 0 0.74" >
		  <geom name = "table2" type="mesh" mesh="table" group="2" rgba="0.35 0.35 0.35 1" mass="0" contype="0" conaffinity="0"/>
		</body>

		<body name="simple_table" pos="0.8 0.6 0.69" quat="1 0 0 0">
			<geom name="simple_table" type="box" size="0.8 0.6 0.05" rgba="0.5 0.5 0.5 0.1"/>
		</body>


	<!-- mug_5 replaced with simple box -->
