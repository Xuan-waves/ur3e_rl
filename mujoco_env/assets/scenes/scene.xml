		<geom type="box" size="0.035 0.035 0.04" rgba="0.3 0.3 0.8 1" friction="3.0 0.5 0.1" solimp="0.998 0.998 0.001" solref="0.001 1" density="2000" condim="6"/>
		<site rgba="0 0 0 0" size="0.005" pos="0 0 -0.04" name="bottom_site_mug_6" />
